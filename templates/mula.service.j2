[Unit]
Description=OpenKat Mula in Docker-compose ({{ openkat_service_root }}/mula)
Requires=docker.service
After=docker.service
Requires=traefik.service
Requires=docker-compose-networks.service
Requires=openkat_postgres.service
Requires=openkat_rabbitmq.service
Requires=openkat_katalogus.service
Requires=openkat_octopoesapi.service

[Service]
Restart=always
WorkingDirectory={{ openkat_service_root }}/mula
TimeoutStartSec=2min
ExecStartPre={{ docker_binary }} compose  -f {{ openkat_service_root }}/mula/docker-compose.yml pull
ExecStart={{ docker_binary }} compose -f {{ openkat_service_root }}/mula/docker-compose.yml up
ExecStop={{ docker_binary }} compose -f {{ openkat_service_root }}/mula/docker-compose.yml stop

[Install]
WantedBy=multi-user.target