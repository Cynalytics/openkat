# {{ ansible_managed }}
services:
  octopoesapiworker:
    hostname: octopoesapiworker
    restart: on-failure
    mem_limit: 1g
    cpus: 2.0
    command: ["worker-beat"]
    image: "{{ openkat_docker_repository }}/openkat-octopoes:{{ openkat_octopoes_api_worker_version }}"
    environment:
      - QUEUE_URI=amqp://{{ openkat_rabbitmq_user }}:{{ openkat_rabbitmq_password }}@rabbitmq:5672/{{ openkat_rabbitmq_vhost }}
      - XTDB_URI=http://crux:3000
      - KATALOGUS_API=http://katalogus:8000
      {# - BYTES_USERNAME="{{ openkat_bytes_user }}"
      - BYTES_PASSWORD="{{ openkat_bytes_password }}" #}

    ulimits:
      nofile:
        soft: 262144
        hard: 262144

    networks:
      openkatinternalnetwork:
        aliases:
          - octopoesapiworker

networks:
  openkatinternalnetwork:
    external: true
