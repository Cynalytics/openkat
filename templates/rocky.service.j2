[Unit]
Description=OpenKat Rocky in Docker-compose ({{ openkat_service_root }}/rocky)
Requires=docker.service
After=docker.service
Requires=traefik.service
Requires=docker-compose-networks.service
Requires=openkat_postgres.service
Requires=openkat_rabbitmq.service
Requires=openkat_octopoesapi.service
Requires=openkat_bytes.service
Requires=openkat_katalogus.service
Requires=openkat_mula.service

[Service]
Restart=always
WorkingDirectory={{ openkat_service_root }}/rocky
TimeoutStartSec=2min
ExecStartPre={{ docker_binary }} compose  -f {{ openkat_service_root }}/rocky/docker-compose.yml pull
ExecStart={{ docker_binary }} compose -f {{ openkat_service_root }}/rocky/docker-compose.yml up
ExecStop={{ docker_binary }} compose -f {{ openkat_service_root }}/rocky/docker-compose.yml stop

[Install]
WantedBy=multi-user.target
